# ─────────────────────────────────────────────────────────────────────────────
# PICASso Automation — Environment Variables
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in the values.
#   cp .env.example .env
# ─────────────────────────────────────────────────────────────────────────────

# Target test environment (qa | dev | ppr)
TEST_ENV=qa

# Base URL override (optional — falls back to config/environments/<env>.ts)
# BASE_URL=https://your-picasso-instance.outsystems.app

# ─────────────────────────────────────────────────────────────────────────────
# Atlassian (optional — only needed for MCP Atlassian integration)
# ─────────────────────────────────────────────────────────────────────────────
# CONFLUENCE_URL=https://your-instance.atlassian.net/wiki
# CONFLUENCE_USERNAME=your.email@company.com
# CONFLUENCE_API_TOKEN=
# JIRA_URL=https://your-instance.atlassian.net
# JIRA_USERNAME=your.email@company.com
# JIRA_API_TOKEN=

# ─────────────────────────────────────────────────────────────────────────────
# Tracker Web UI — Authentication
# ─────────────────────────────────────────────────────────────────────────────
# Long random string used to sign session cookies.  Generate one with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=replace-with-a-long-random-string

# Initial admin account — seeded automatically on first startup if no users exist.
# Once users are in the DB these vars are no longer read for seeding, but keep them
# in your deployment environment for reference / re-seeding after a DB reset.
TRACKER_ADMIN_USER=admin
TRACKER_ADMIN_PASSWORD=change-me-before-deploying

# Optional: custom port for the Tracker UI (default: 3005)
# TRACKER_PORT=3005
