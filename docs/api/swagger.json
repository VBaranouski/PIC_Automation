{
  "openapi": "3.0.3",
  "info": {
    "title": "PICASso Test Scenario Tracker API",
    "description": "REST API for the PICASso automation test scenario tracker — manages test scenarios, execution, reporting, and XLSX import/export.",
    "version": "1.0.0",
    "contact": {
      "name": "PICASso Automation Team"
    }
  },
  "servers": [
    {
      "url": "http://localhost:3005",
      "description": "Local tracker server"
    }
  ],
  "tags": [
    { "name": "Scenarios", "description": "CRUD operations for test scenarios" },
    { "name": "Status Shortcuts", "description": "Quick-set automation state, execution status, priority, hold" },
    { "name": "Groups", "description": "Manage group labels and scenario-group associations" },
    { "name": "Stats & Metadata", "description": "Dashboard statistics, enum values, workflow lists" },
    { "name": "Import / Export", "description": "JSON import/export and spec-file sync" },
    { "name": "XLSX Workflow", "description": "Excel import, export, and file upload" },
    { "name": "Test Runner", "description": "Start, monitor, and cancel Playwright test runs" },
    { "name": "Allure Reports", "description": "Allure report generation and result querying" }
  ],
  "paths": {
    "/api/scenarios": {
      "get": {
        "tags": ["Scenarios"],
        "summary": "List scenarios with optional filters and pagination",
        "operationId": "listScenarios",
        "parameters": [
          { "name": "automation_state", "in": "query", "schema": { "$ref": "#/components/schemas/AutomationState" } },
          { "name": "execution_status", "in": "query", "schema": { "$ref": "#/components/schemas/ExecutionStatus" } },
          { "name": "priority", "in": "query", "schema": { "$ref": "#/components/schemas/Priority" } },
          { "name": "feature_area", "in": "query", "schema": { "$ref": "#/components/schemas/FeatureArea" } },
          { "name": "group", "in": "query", "schema": { "type": "string" }, "description": "Filter by group tag" },
          { "name": "workflow", "in": "query", "schema": { "type": "string" }, "description": "Filter by workflow name" },
          { "name": "search", "in": "query", "schema": { "type": "string" }, "description": "Free-text search across id, title, description" },
          { "name": "spec_file", "in": "query", "schema": { "type": "string" }, "description": "Filter by spec file path" },
          { "name": "page", "in": "query", "schema": { "type": "integer", "default": 1, "minimum": 1 } },
          { "name": "limit", "in": "query", "schema": { "type": "integer", "default": 50, "minimum": 1, "maximum": 5000 } }
        ],
        "responses": {
          "200": {
            "description": "Paginated list of scenarios",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "items": { "type": "array", "items": { "$ref": "#/components/schemas/EnrichedScenario" } },
                    "total": { "type": "integer" },
                    "page": { "type": "integer" },
                    "limit": { "type": "integer" },
                    "pages": { "type": "integer" }
                  }
                }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" }
        }
      },
      "post": {
        "tags": ["Scenarios"],
        "summary": "Create a new test scenario",
        "operationId": "createScenario",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/ScenarioCreate" }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Scenario created",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Scenario" } } }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "409": { "description": "Scenario with this ID already exists", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } }
        }
      }
    },
    "/api/scenarios/{id}": {
      "get": {
        "tags": ["Scenarios"],
        "summary": "Get a single scenario by ID",
        "operationId": "getScenario",
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "responses": {
          "200": {
            "description": "Scenario found",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/EnrichedScenario" } } }
          },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      },
      "put": {
        "tags": ["Scenarios"],
        "summary": "Update a scenario (auto-detects content changes)",
        "description": "If title, description, steps, or expected_results change and no explicit automation_state is set, the state is auto-set to 'updated' and execution_status to 'not-executed'.",
        "operationId": "updateScenario",
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/ScenarioUpdate" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Scenario updated",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Scenario" } } }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      },
      "delete": {
        "tags": ["Scenarios"],
        "summary": "Delete a scenario",
        "operationId": "deleteScenario",
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "responses": {
          "200": {
            "description": "Scenario deleted",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/OkResponse" } } }
          },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      }
    },
    "/api/scenarios/{id}/auto-state": {
      "post": {
        "tags": ["Status Shortcuts"],
        "summary": "Set automation state for a scenario",
        "operationId": "setAutoState",
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["state"],
                "properties": {
                  "state": { "$ref": "#/components/schemas/AutomationState" }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Updated scenario", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Scenario" } } } },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      }
    },
    "/api/scenarios/{id}/priority": {
      "post": {
        "tags": ["Status Shortcuts"],
        "summary": "Set priority for a scenario",
        "operationId": "setPriority",
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["priority"],
                "properties": {
                  "priority": { "$ref": "#/components/schemas/Priority" }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Updated scenario", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Scenario" } } } },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      }
    },
    "/api/scenarios/{id}/exec-status": {
      "post": {
        "tags": ["Status Shortcuts"],
        "summary": "Set execution status for a scenario",
        "operationId": "setExecStatus",
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["status"],
                "properties": {
                  "status": { "$ref": "#/components/schemas/ExecutionStatus" }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Updated scenario", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Scenario" } } } },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      }
    },
    "/api/scenarios/{id}/hold": {
      "post": {
        "tags": ["Status Shortcuts"],
        "summary": "Put a scenario on hold (auto-skipped in test runs)",
        "operationId": "holdScenario",
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "responses": {
          "200": { "description": "Updated scenario", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Scenario" } } } },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      }
    },
    "/api/scenarios/{id}/unhold": {
      "post": {
        "tags": ["Status Shortcuts"],
        "summary": "Remove a scenario from hold",
        "operationId": "unholdScenario",
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "responses": {
          "200": { "description": "Updated scenario", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Scenario" } } } },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      }
    },
    "/api/groups": {
      "get": {
        "tags": ["Groups"],
        "summary": "List all groups with scenario counts",
        "operationId": "listGroups",
        "responses": {
          "200": {
            "description": "Array of groups with counts",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "name": { "type": "string" },
                      "description": { "type": "string" },
                      "count": { "type": "integer" }
                    }
                  }
                }
              }
            }
          }
        }
      },
      "post": {
        "tags": ["Groups"],
        "summary": "Create a new group label",
        "operationId": "createGroup",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["name"],
                "properties": {
                  "name": { "type": "string" },
                  "description": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": {
          "201": { "description": "Group created", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/OkResponse" } } } },
          "400": { "$ref": "#/components/responses/BadRequest" }
        }
      }
    },
    "/api/scenarios/{id}/groups": {
      "post": {
        "tags": ["Groups"],
        "summary": "Add a group tag to a scenario",
        "operationId": "addGroupToScenario",
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["group"],
                "properties": {
                  "group": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Updated scenario with groups", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Scenario" } } } },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      }
    },
    "/api/scenarios/{id}/groups/{group}": {
      "delete": {
        "tags": ["Groups"],
        "summary": "Remove a group tag from a scenario",
        "operationId": "removeGroupFromScenario",
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "string" } },
          { "name": "group", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "responses": {
          "200": { "description": "Updated scenario", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Scenario" } } } },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      }
    },
    "/api/scenarios/{id}/details": {
      "get": {
        "tags": ["Stats & Metadata"],
        "summary": "Get scenario details (steps, expected results, execution notes)",
        "operationId": "getScenarioDetails",
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "responses": {
          "200": {
            "description": "Scenario details",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ScenarioDetails" }
              }
            }
          }
        }
      }
    },
    "/api/stats": {
      "get": {
        "tags": ["Stats & Metadata"],
        "summary": "Dashboard statistics aggregated by state, status, priority, area, group",
        "operationId": "getStats",
        "responses": {
          "200": {
            "description": "Aggregated statistics",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "total": { "type": "integer" },
                    "by_automation_state": { "type": "object", "additionalProperties": { "type": "integer" } },
                    "by_execution_status": { "type": "object", "additionalProperties": { "type": "integer" } },
                    "by_priority": { "type": "object", "additionalProperties": { "type": "integer" } },
                    "by_feature_area": { "type": "object", "additionalProperties": { "type": "integer" } },
                    "by_group": { "type": "object", "additionalProperties": { "type": "integer" } }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/workflows": {
      "get": {
        "tags": ["Stats & Metadata"],
        "summary": "List distinct workflow names for UI dropdowns",
        "operationId": "getWorkflows",
        "responses": {
          "200": {
            "description": "Array of workflow names",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": { "type": "string" }
                }
              }
            }
          }
        }
      }
    },
    "/api/meta": {
      "get": {
        "tags": ["Stats & Metadata"],
        "summary": "Enum values for all dropdowns (states, statuses, priorities, areas, groups)",
        "operationId": "getMeta",
        "responses": {
          "200": {
            "description": "Enum metadata",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "automation_states": { "type": "array", "items": { "type": "string" } },
                    "execution_statuses": { "type": "array", "items": { "type": "string" } },
                    "priorities": { "type": "array", "items": { "type": "string" } },
                    "feature_areas": { "type": "array", "items": { "type": "string" } },
                    "default_groups": { "type": "array", "items": { "type": "string" } }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/sync": {
      "post": {
        "tags": ["Import / Export"],
        "summary": "Sync tracker DB with on-disk spec files (detect orphans, new IDs)",
        "operationId": "syncWithSpecFiles",
        "responses": {
          "200": {
            "description": "Sync result",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "added": { "type": "integer" },
                    "removed": { "type": "integer" },
                    "updated": { "type": "integer" },
                    "errors": { "type": "array", "items": { "type": "string" } }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/export": {
      "get": {
        "tags": ["Import / Export"],
        "summary": "Export all scenarios as JSON",
        "operationId": "exportToJson",
        "responses": {
          "200": {
            "description": "JSON export file",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/TrackerExport" }
              }
            }
          }
        }
      }
    },
    "/api/import": {
      "post": {
        "tags": ["Import / Export"],
        "summary": "Import scenarios from JSON",
        "operationId": "importFromJson",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/TrackerExport" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Import result",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "imported": { "type": "integer" },
                    "skipped": { "type": "integer" },
                    "errors": { "type": "array", "items": { "type": "string" } }
                  }
                }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" }
        }
      }
    },
    "/api/import-files": {
      "get": {
        "tags": ["XLSX Workflow"],
        "summary": "List .xlsx files available in the input directory",
        "operationId": "listImportFiles",
        "responses": {
          "200": {
            "description": "List of xlsx filenames",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "files": { "type": "array", "items": { "type": "string" } }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/xlsx-export": {
      "post": {
        "tags": ["XLSX Workflow"],
        "summary": "Export scenarios for a workflow to XLSX and download",
        "operationId": "xlsxExport",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["workflow"],
                "properties": {
                  "workflow": { "type": "string", "description": "Workflow name (must exist in DB)" }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "XLSX file download",
            "content": {
              "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet": {
                "schema": { "type": "string", "format": "binary" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "500": { "$ref": "#/components/responses/ServerError" }
        }
      }
    },
    "/api/xlsx-import": {
      "post": {
        "tags": ["XLSX Workflow"],
        "summary": "Import scenarios from an existing XLSX file for a workflow",
        "operationId": "xlsxImport",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["workflow", "filename"],
                "properties": {
                  "workflow": { "type": "string", "description": "Workflow name (must exist in DB)" },
                  "filename": { "type": "string", "description": "Name of .xlsx file in the input directory" }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Import result",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": { "type": "boolean" },
                    "output": { "type": "string" }
                  }
                }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "404": { "$ref": "#/components/responses/NotFound" },
          "500": { "$ref": "#/components/responses/ServerError" }
        }
      }
    },
    "/api/xlsx-upload": {
      "post": {
        "tags": ["XLSX Workflow"],
        "summary": "Upload an XLSX file to the input directory",
        "operationId": "xlsxUpload",
        "parameters": [
          { "name": "X-Filename", "in": "header", "required": true, "schema": { "type": "string" }, "description": "Filename for the uploaded .xlsx file" }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet": {
              "schema": { "type": "string", "format": "binary" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "File uploaded",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": { "type": "boolean" },
                    "filename": { "type": "string" }
                  }
                }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "500": { "$ref": "#/components/responses/ServerError" }
        }
      }
    },
    "/api/run": {
      "post": {
        "tags": ["Test Runner"],
        "summary": "Start a Playwright test run",
        "operationId": "startRun",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["specFiles"],
                "properties": {
                  "specFiles": { "type": "array", "items": { "type": "string" }, "description": "Relative paths to spec files (e.g. tests/doc/doc-detail.spec.ts)" },
                  "project": { "type": "string", "description": "Playwright project name (auto-detected if omitted)" },
                  "grep": { "type": "string", "description": "Grep pattern to filter tests" },
                  "headed": { "type": "boolean", "description": "Run in headed browser mode", "default": false }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Run started",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "id": { "type": "string" },
                    "status": { "type": "string", "enum": ["running"] },
                    "specFiles": { "type": "array", "items": { "type": "string" } },
                    "project": { "type": "string" }
                  }
                }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "409": { "description": "A test run is already in progress", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } }
        }
      }
    },
    "/api/run/status": {
      "get": {
        "tags": ["Test Runner"],
        "summary": "Poll current run state with incremental line output",
        "operationId": "getRunStatus",
        "parameters": [
          { "name": "since", "in": "query", "schema": { "type": "integer", "default": 0 }, "description": "Line index to resume from (for incremental polling)" }
        ],
        "responses": {
          "200": {
            "description": "Current run status",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "id": { "type": "string" },
                    "status": { "type": "string", "enum": ["idle", "running", "passed", "failed", "cancelled"] },
                    "specFiles": { "type": "array", "items": { "type": "string" } },
                    "totalTests": { "type": "integer", "nullable": true },
                    "workers": { "type": "integer", "nullable": true },
                    "project": { "type": "string" },
                    "grep": { "type": "string" },
                    "exitCode": { "type": "integer", "nullable": true },
                    "summary": { "type": "string" },
                    "elapsed": { "type": "integer", "description": "Elapsed time in ms (0 if not running)" },
                    "totalLines": { "type": "integer" },
                    "lines": { "type": "array", "items": { "type": "string" } },
                    "since": { "type": "integer" }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/run/cancel": {
      "post": {
        "tags": ["Test Runner"],
        "summary": "Cancel the currently running test (SIGTERM → SIGKILL fallback)",
        "operationId": "cancelRun",
        "responses": {
          "200": {
            "description": "Cancellation initiated",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "ok": { "type": "boolean" },
                    "message": { "type": "string" }
                  }
                }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" }
        }
      }
    },
    "/api/run/history": {
      "get": {
        "tags": ["Test Runner"],
        "summary": "Recent test run history (up to 50 entries)",
        "operationId": "getRunHistory",
        "responses": {
          "200": {
            "description": "Run history array",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": { "$ref": "#/components/schemas/RunHistoryEntry" }
                }
              }
            }
          }
        }
      }
    },
    "/api/run/sync-results": {
      "post": {
        "tags": ["Test Runner"],
        "summary": "Sync scenario statuses from the latest Playwright JSON report",
        "operationId": "syncResults",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "specFiles": { "type": "array", "items": { "type": "string" }, "description": "Spec files to sync (defaults to all in the report)" }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Sync completed",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "ok": { "type": "boolean" },
                    "syncedSpecFiles": { "type": "array", "items": { "type": "string" } }
                  }
                }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" }
        }
      }
    },
    "/api/run/resolve-project": {
      "post": {
        "tags": ["Test Runner"],
        "summary": "Resolve the best Playwright project for a spec file",
        "operationId": "resolveProject",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["specFile"],
                "properties": {
                  "specFile": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Resolved project",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "specFile": { "type": "string" },
                    "project": { "type": "string" }
                  }
                }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" }
        }
      }
    },
    "/api/run/resolve-scenario": {
      "post": {
        "tags": ["Test Runner"],
        "summary": "Resolve a single scenario to an exact grep target for test execution",
        "operationId": "resolveScenario",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["scenarioId", "specFile"],
                "properties": {
                  "scenarioId": { "type": "string" },
                  "specFile": { "type": "string" },
                  "title": { "type": "string" },
                  "description": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Resolved grep target",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "scenarioId": { "type": "string" },
                    "specFile": { "type": "string" },
                    "grep": { "type": "string" },
                    "project": { "type": "string" }
                  }
                }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      }
    },
    "/api/run/resolve-subsection": {
      "post": {
        "tags": ["Test Runner"],
        "summary": "Resolve a subsection to a describe-level grep target",
        "operationId": "resolveSubsection",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["subsection", "specFile"],
                "properties": {
                  "subsection": { "type": "string" },
                  "specFile": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Resolved grep target",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "subsection": { "type": "string" },
                    "specFile": { "type": "string" },
                    "grep": { "type": "string" },
                    "project": { "type": "string" }
                  }
                }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      }
    },
    "/api/spec-files": {
      "get": {
        "tags": ["Test Runner"],
        "summary": "List all spec files on disk for the run dialog",
        "operationId": "listSpecFiles",
        "responses": {
          "200": {
            "description": "Array of spec file paths",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": { "type": "string" }
                }
              }
            }
          }
        }
      }
    },
    "/api/allure/generate": {
      "post": {
        "tags": ["Allure Reports"],
        "summary": "Generate Allure HTML report from allure-results",
        "operationId": "generateAllureReport",
        "responses": {
          "200": {
            "description": "Report generated",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/OkResponse" } } }
          },
          "500": { "$ref": "#/components/responses/ServerError" }
        }
      }
    },
    "/api/allure/summary": {
      "get": {
        "tags": ["Allure Reports"],
        "summary": "High-level stats and per-suite breakdown from Allure results",
        "operationId": "getAllureSummary",
        "responses": {
          "200": {
            "description": "Allure summary",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "total": { "type": "integer" },
                    "byStatus": { "type": "object", "additionalProperties": { "type": "integer" } },
                    "bySuite": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "name": { "type": "string" },
                          "total": { "type": "integer" },
                          "passed": { "type": "integer" },
                          "failed": { "type": "integer" },
                          "skipped": { "type": "integer" },
                          "broken": { "type": "integer" },
                          "duration": { "type": "integer" }
                        }
                      }
                    },
                    "lastRun": { "type": "integer", "description": "Epoch ms of the most recent test completion" },
                    "totalDuration": { "type": "integer" },
                    "reportName": { "type": "string" },
                    "reportCreatedAt": { "type": "integer" }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/allure/results": {
      "get": {
        "tags": ["Allure Reports"],
        "summary": "Paginated Allure test results with filtering",
        "operationId": "getAllureResults",
        "parameters": [
          { "name": "status", "in": "query", "schema": { "type": "string" }, "description": "Filter by status (passed, failed, broken, skipped)" },
          { "name": "suite", "in": "query", "schema": { "type": "string" }, "description": "Filter by suite name" },
          { "name": "search", "in": "query", "schema": { "type": "string" }, "description": "Free-text search" },
          { "name": "tag", "in": "query", "schema": { "type": "string" }, "description": "Filter by Allure tag" },
          { "name": "page", "in": "query", "schema": { "type": "integer", "default": 1, "minimum": 1 } },
          { "name": "limit", "in": "query", "schema": { "type": "integer", "default": 100, "minimum": 1, "maximum": 500 } }
        ],
        "responses": {
          "200": {
            "description": "Paginated Allure results",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "items": { "type": "array", "items": { "$ref": "#/components/schemas/AllureResult" } },
                    "total": { "type": "integer" },
                    "page": { "type": "integer" },
                    "limit": { "type": "integer" },
                    "pages": { "type": "integer" }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/allure/suites": {
      "get": {
        "tags": ["Allure Reports"],
        "summary": "List all unique Allure suites with test counts",
        "operationId": "getAllureSuites",
        "responses": {
          "200": {
            "description": "Array of suites",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "name": { "type": "string" },
                      "count": { "type": "integer" }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/allure/failures": {
      "get": {
        "tags": ["Allure Reports"],
        "summary": "Failed and broken tests with error details",
        "operationId": "getAllureFailures",
        "responses": {
          "200": {
            "description": "Array of failures",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "uuid": { "type": "string" },
                      "name": { "type": "string" },
                      "status": { "type": "string", "enum": ["failed", "broken"] },
                      "suite": { "type": "string" },
                      "subSuite": { "type": "string" },
                      "duration": { "type": "integer" },
                      "message": { "type": "string" },
                      "trace": { "type": "string" },
                      "tags": { "type": "array", "items": { "type": "string" } }
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "AutomationState": {
        "type": "string",
        "enum": ["pending", "automated", "on-hold", "updated"],
        "description": "Lifecycle state of test automation"
      },
      "ExecutionStatus": {
        "type": "string",
        "enum": ["passed", "not-executed", "skipped", "failed-defect"],
        "description": "Result of the last test execution"
      },
      "Priority": {
        "type": "string",
        "enum": ["P1", "P2", "P3", "Edge"]
      },
      "FeatureArea": {
        "type": "string",
        "enum": ["auth", "landing", "products", "releases", "doc", "reports", "backoffice", "integrations", "other"]
      },
      "Scenario": {
        "type": "object",
        "properties": {
          "id": { "type": "string", "description": "Unique scenario ID (e.g. DOC-DETAIL-001)" },
          "title": { "type": "string" },
          "description": { "type": "string" },
          "automation_state": { "$ref": "#/components/schemas/AutomationState" },
          "execution_status": { "$ref": "#/components/schemas/ExecutionStatus" },
          "priority": { "$ref": "#/components/schemas/Priority" },
          "feature_area": { "$ref": "#/components/schemas/FeatureArea" },
          "spec_file": { "type": "string", "description": "Mapped Playwright spec file path" },
          "workflow": { "type": "string" },
          "subsection": { "type": "string" },
          "groups": { "type": "array", "items": { "type": "string" } },
          "steps": { "type": "array", "items": { "type": "string" } },
          "expected_results": { "type": "array", "items": { "type": "string" } },
          "execution_notes": { "type": "string" },
          "created_at": { "type": "string", "format": "date-time" },
          "updated_at": { "type": "string", "format": "date-time" }
        },
        "required": ["id", "title"]
      },
      "EnrichedScenario": {
        "allOf": [
          { "$ref": "#/components/schemas/Scenario" },
          {
            "type": "object",
            "properties": {
              "hasSpecFile": { "type": "boolean", "description": "Whether the mapped spec file exists on disk" },
              "canRunIndividually": { "type": "boolean", "description": "Whether this scenario can be grep-targeted for individual execution" }
            }
          }
        ]
      },
      "ScenarioCreate": {
        "type": "object",
        "required": ["id", "title"],
        "properties": {
          "id": { "type": "string" },
          "title": { "type": "string" },
          "description": { "type": "string" },
          "automation_state": { "$ref": "#/components/schemas/AutomationState" },
          "execution_status": { "$ref": "#/components/schemas/ExecutionStatus" },
          "priority": { "$ref": "#/components/schemas/Priority" },
          "feature_area": { "$ref": "#/components/schemas/FeatureArea" },
          "spec_file": { "type": "string" },
          "workflow": { "type": "string" },
          "groups": { "type": "array", "items": { "type": "string" } },
          "steps": { "type": "array", "items": { "type": "string" } },
          "expected_results": { "type": "array", "items": { "type": "string" } },
          "execution_notes": { "type": "string" }
        }
      },
      "ScenarioUpdate": {
        "type": "object",
        "properties": {
          "title": { "type": "string" },
          "description": { "type": "string" },
          "automation_state": { "$ref": "#/components/schemas/AutomationState" },
          "execution_status": { "$ref": "#/components/schemas/ExecutionStatus" },
          "priority": { "$ref": "#/components/schemas/Priority" },
          "feature_area": { "$ref": "#/components/schemas/FeatureArea" },
          "spec_file": { "type": "string" },
          "workflow": { "type": "string" },
          "groups": { "type": "array", "items": { "type": "string" } },
          "steps": { "type": "array", "items": { "type": "string" } },
          "expected_results": { "type": "array", "items": { "type": "string" } },
          "execution_notes": { "type": "string" }
        }
      },
      "ScenarioDetails": {
        "type": "object",
        "properties": {
          "scenario_id": { "type": "string" },
          "steps": { "type": "array", "items": { "type": "string" } },
          "expected_results": { "type": "array", "items": { "type": "string" } },
          "execution_notes": { "type": "string" }
        }
      },
      "TrackerExport": {
        "type": "object",
        "properties": {
          "version": { "type": "integer" },
          "exported_at": { "type": "string", "format": "date-time" },
          "scenarios": { "type": "array", "items": { "$ref": "#/components/schemas/Scenario" } }
        },
        "required": ["scenarios"]
      },
      "RunHistoryEntry": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "specFiles": { "type": "array", "items": { "type": "string" } },
          "project": { "type": "string" },
          "grep": { "type": "string" },
          "status": { "type": "string", "enum": ["passed", "failed", "cancelled"] },
          "startTime": { "type": "string", "format": "date-time" },
          "endTime": { "type": "string", "format": "date-time" },
          "duration": { "type": "integer", "description": "Duration in milliseconds" },
          "outputLineCount": { "type": "integer" },
          "summary": { "type": "string" }
        }
      },
      "AllureResult": {
        "type": "object",
        "properties": {
          "uuid": { "type": "string" },
          "name": { "type": "string" },
          "status": { "type": "string" },
          "statusDetails": {
            "type": "object",
            "properties": {
              "message": { "type": "string" },
              "trace": { "type": "string" }
            }
          },
          "start": { "type": "integer", "description": "Epoch ms" },
          "stop": { "type": "integer", "description": "Epoch ms" },
          "duration": { "type": "integer", "description": "Duration in ms" },
          "suite": { "type": "string" },
          "subSuite": { "type": "string" },
          "parentSuite": { "type": "string" },
          "tags": { "type": "array", "items": { "type": "string" } },
          "fullName": { "type": "string" },
          "parameters": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "name": { "type": "string" },
                "value": { "type": "string" }
              }
            }
          }
        }
      },
      "OkResponse": {
        "type": "object",
        "properties": {
          "ok": { "type": "boolean", "example": true }
        }
      },
      "Error": {
        "type": "object",
        "properties": {
          "error": { "type": "string" }
        }
      }
    },
    "responses": {
      "BadRequest": {
        "description": "Invalid request parameters",
        "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } }
      },
      "NotFound": {
        "description": "Resource not found",
        "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } }
      },
      "ServerError": {
        "description": "Internal server error",
        "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } }
      }
    }
  }
}
